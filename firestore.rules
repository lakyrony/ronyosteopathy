rules_version = '2';

// Firestore security rules — clinic app (clinic.html) + public booking form (booking.html)
//
// HOW TO APPLY (one-time, ~2 minutes):
//   1. Open https://console.firebase.google.com → project "clinic-rony"
//   2. Firestore Database → Rules (כללים)
//   3. Replace everything with the contents of this file → Publish (פרסם)
//
// What this enforces:
//   - Only Rony's Google account can read/write patients, appointments and settings
//   - Anyone can READ public availability (needed by the booking page)
//   - Anyone can CREATE a booking request, but ONLY with the exact expected fields,
//     sane lengths and formats — blocks spam/garbage writes
//   - Nobody except Rony can read, change or delete booking requests

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'laky.rony@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // Public availability (schedule + taken slots) — booking.html reads this
    match /publicData/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Booking requests from the public form
    match /publicBookings/{id} {
      allow read, delete: if isOwner();
      allow update: if false;
      allow create: if validBooking();

      function validBooking() {
        let d = request.resource.data;
        return d.keys().hasOnly(['name','age','phone','email','problem','patType',
            'healthConditions','healthOther','takingMedication','medications',
            'recentSurgeries','surgeryDetails','date','time','status','createdAt'])
          && d.name is string && d.name.size() >= 2 && d.name.size() <= 60
          && d.phone is string && d.phone.size() >= 9 && d.phone.size() <= 15
          && (d.age == null || (d.age is int && d.age >= 0 && d.age <= 120))
          && d.email is string && d.email.size() <= 80
          && d.problem is string && d.problem.size() <= 500
          && d.patType in ['adult', 'baby']
          && d.healthConditions is list && d.healthConditions.size() <= 12
          && d.healthOther is string && d.healthOther.size() <= 200
          && (d.takingMedication == null || d.takingMedication is bool)
          && d.medications is string && d.medications.size() <= 300
          && (d.recentSurgeries == null || d.recentSurgeries is bool)
          && d.surgeryDetails is string && d.surgeryDetails.size() <= 300
          && d.date is string && d.date.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}')
          && d.time is string && d.time.matches('[0-9]{2}:[0-9]{2}')
          && d.status == 'pending'
          && d.createdAt == request.time;
      }
    }

    // Clinic data — patients, appointments, config. Owner only, and only her own tree.
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner() && request.auth.uid == uid;
    }
  }
}
